# Der optionale private Fork @neelegirly/baileys deklariert einen anderen
# sharp-Peer (^0.32.6) als das öffentliche baileys (*). Ohne diese Zeile bricht
# npms strikter Peer-Resolver mit ERESOLVE ab. legacy-peer-deps löst Peer-
# Konflikte tolerant — npm install läuft dann sauber durch, egal ob der private
# Fork erreichbar ist oder nicht. (Enthält KEINE Secrets — gefahrlos committbar.)
legacy-peer-deps=true
