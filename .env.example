# ===========================================================================
#  OniSelf-Bot — Konfiguration
# ---------------------------------------------------------------------------
#  Kopiere diese Datei nach ".env" und fülle die Werte aus:
#      cp .env.example .env
#  Die .env wird NIE committet (.gitignore). Keine Secrets im Code.
# ===========================================================================

# ── Basis ───────────────────────────────────────────────────────────────────
# Befehls-Prefix (Standard: ".")
ONISELF_PREFIX=.
# Anzeigename des Bots
ONISELF_BOTNAME=OniSelf

# Owner-Nummer(n) im internationalen Format, NUR Ziffern, kommasepariert.
# Beispiel (Deutschland): 4915123456789
# Diese Nummer(n) dürfen owner-only Befehle nutzen. Bleibt LOKAL — landet nie
# in einem öffentlichen Repo (siehe .gitignore).
OWNER_NUMBER=

# Selfbot-Lockdown:
#   true  → NUR der Owner / deine eigenen Nachrichten dürfen Befehle auslösen
#   false → jeder darf normale Befehle nutzen (owner-only Befehle bleiben gesperrt)
ONISELF_OWNER_ONLY=false

# ── Pairing ──────────────────────────────────────────────────────────────────
# Optional: Nummer (nur Ziffern) für Pairing-Code statt QR-Scan.
# Leer lassen → QR-Code im Terminal. Bei gesetzter Nummer druckt der Bot einen
# 8-stelligen Code (WhatsApp → Verknüpfte Geräte → "Mit Nummer verknüpfen").
ONISELF_PAIR_NUMBER=

# ── Stable Diffusion (KI-Bilder) ─────────────────────────────────────────────
# A1111-Endpoint (Automatic1111 WebUI mit --api). Reihenfolge der Auflösung:
#   1) SD_ENDPOINT        ← manueller Override (z.B. Cloudflare-Tunnel-URL)
#   2) cache/colab.json   ← falls ein Colab-Notebook die Tunnel-URL dort ablegt
#   3) SD_COLAB_URL       ← zweiter Fallback
#   4) SD_FALLBACK_ENDPOINT (Standard: http://127.0.0.1:7860 — lokaler A1111)
SD_ENDPOINT=
SD_COLAB_URL=
SD_FALLBACK_ENDPOINT=http://127.0.0.1:7860
SD_TIMEOUT_MS=180000
# Online-Notfall-Fallback (image.pollinations.ai), wenn keine GPU erreichbar ist.
SD_POLLINATIONS_FALLBACK=true

# ── Text-KI / Chat-Persona (.chat) ───────────────────────────────────────────
# Google Gemini API-Key (https://aistudio.google.com/app/apikey).
# Ohne Key antwortet .chat mit einem freundlichen Hinweis statt KI-Text.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
CHAT_MAX_HISTORY=10

# ── Downloader-Limits ────────────────────────────────────────────────────────
DOWNLOAD_MAX_MB=100
DOWNLOAD_TIMEOUT_MS=60000

# ── Heartbeat (optional) ─────────────────────────────────────────────────────
# Wenn gesetzt, pingt der Bot diese URL regelmäßig (z.B. ein Status-Monitor).
# Leer lassen → Heartbeat komplett aus.
HEARTBEAT_URL=
HEARTBEAT_INTERVAL_S=60
